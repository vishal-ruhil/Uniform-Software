rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 0. Global Safety Net ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- 1. Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.firebase.sign_in_provider == 'google.com' // Google is trusted
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Auth tokens never contain roles. Rules must look up roles.
    // However, we have whitelisted emails for emergency admin access.
    function isWhitelistedAdmin() {
      return isSignedIn() && (request.auth.token.email in [
        'vishal@unicrm.in', 
        'vishaldalamwala@gmail.com', 
        'ruhilvishal123@gmail.com'
      ]);
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function hasRole(role) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserData(request.auth.uid).role == role
      );
    }

    function isAdmin() {
      return isWhitelistedAdmin() || hasRole('Admin');
    }

    function isEditor() {
      return hasRole('Editor') || hasRole('Admin');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- 2. Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'email', 'name', 'role', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.email is string && data.email.size() <= 128 &&
             data.name is string && data.name.size() <= 128 &&
             data.role in ['Admin', 'Editor', 'Viewer'] &&
             data.createdAt is string &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 2048)) &&
             (!('emailVerified' in data) || data.emailVerified is bool);
    }

    function isValidSale(data) {
      return data.keys().hasAll(['id', 'srNo', 'name', 'studentClass', 'items', 'totalAmount', 'date', 'timestamp', 'paymentMode']) &&
             data.id is string && data.id.size() <= 128 &&
             data.srNo is number &&
             data.name is string && data.name.size() <= 256 &&
             data.studentClass is string && data.studentClass.size() <= 128 &&
             data.items is list && data.items.size() <= 100 &&
             data.totalAmount is number &&
             data.date is string && data.date.size() <= 64 &&
             data.timestamp is string && data.timestamp.size() <= 64 &&
             data.paymentMode in ['UPI', 'Cash', 'Pending'] &&
             (!('paidAmount' in data) || data.paidAmount is number) &&
             (!('paymentDate' in data) || (data.paymentDate is string && data.paymentDate.size() <= 64)) &&
             (!('notes' in data) || (data.notes is string && data.notes.size() <= 10000)) &&
             (!('discountPercent' in data) || data.discountPercent is number) &&
             (!('customData' in data) || data.customData is map);
    }

    function isValidPricing(data) {
      return data.keys().hasAll(['data']) &&
             data.data is map &&
             (!('order' in data) || data.order is list);
    }

    function isValidSettings(data) {
       return data is map;
    }

    // --- 3. Resource Rules ---

    // Collection: Users
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().role == 'Viewer' || 
        incoming().role == 'Editor' || 
        (incoming().role == 'Admin' && isWhitelistedAdmin())
      );
      
      allow update: if (isOwner(userId) || isAdmin()) && (
        // Immutable fields
        incoming().id == existing().id &&
        incoming().email == existing().email &&
        incoming().createdAt == existing().createdAt &&
        // Validation
        isValidUser(incoming()) &&
        (
          isAdmin() || 
          (
            // Action: Edit Profile
            incoming().diff(existing()).affectedKeys().hasOnly(['name', 'photoURL', 'emailVerified'])
          )
        )
      );
      
      allow delete: if isAdmin() && userId != request.auth.uid;
    }

    // Collection: Pricing (Singleton document 'current')
    match /pricing/{docId} {
      allow read: if isSignedIn();
      allow write: if isEditor() && isValidPricing(incoming()) && isValidId(docId);
    }

    // Collection: Sales
    match /sales/{saleId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (isAdmin() || isEditor() || resource.data.name != null); // Force data evaluate for list
      
      allow create: if isEditor() && isValidSale(incoming()) && isEmailVerified();
      
      allow update: if isEditor() && isValidSale(incoming()) && isEmailVerified() && (
        // Action: Record changes
        incoming().id == existing().id &&
        incoming().srNo == existing().srNo &&
        (
          isAdmin() || 
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'studentClass', 'items', 'totalAmount', 'discountPercent', 'paymentMode', 'paidAmount', 'paymentDate', 'notes', 'customData'])
        )
      );
      
      allow delete: if isAdmin();
    }

    // Collection: Settings
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidSettings(incoming()) && isValidId(settingId);
    }
  }
}
