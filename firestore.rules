rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 0. Global Safety Net ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- 1. Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.firebase.sign_in_provider == 'google.com' // Google is trusted
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Auth tokens never contain roles. Rules must look up roles.
    // However, we have whitelisted emails for emergency admin access.
    function isWhitelistedAdmin() {
      return isSignedIn() && (request.auth.token.email in [
        'vishal@unicrm.in', 
        'vishaldalamwala@gmail.com', 
        'ruhilvishal123@gmail.com',
        'admin@nextgeninternationalschool.com'
      ]);
    }

    function isAdmin() {
      return isWhitelistedAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin'
      );
    }

    function isEditor() {
      return isAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Editor'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- 2. Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'email', 'name', 'role', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.email is string && data.email.size() <= 128 &&
             data.name is string && data.name.size() <= 128 &&
             data.role in ['Admin', 'Editor', 'Viewer'] &&
             data.createdAt is string &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 2048)) &&
             (!('emailVerified' in data) || data.emailVerified is bool);
    }

    function isValidSale(data) {
      return data.keys().hasAll(['id', 'srNo', 'name', 'studentClass', 'items', 'totalAmount', 'date', 'timestamp', 'paymentMode']) &&
             data.id is string && data.id.size() <= 128 &&
             data.srNo is number &&
             data.name is string && data.name.size() <= 256 &&
             data.studentClass is string && data.studentClass.size() <= 128 &&
             data.items is list && data.items.size() <= 100 &&
             data.totalAmount is number &&
             data.date is string && data.date.size() <= 64 &&
             data.timestamp is string && data.timestamp.size() <= 64 &&
             data.paymentMode in ['UPI', 'Cash', 'Pending'] &&
             (!('paidAmount' in data) || data.paidAmount is number) &&
             (!('paymentDate' in data) || (data.paymentDate is string && data.paymentDate.size() <= 64)) &&
             (!('notes' in data) || (data.notes is string && data.notes.size() <= 10000)) &&
             (!('discountPercent' in data) || data.discountPercent is number) &&
             (!('customData' in data) || data.customData is map);
    }

    function isValidPricing(data) {
      return data.keys().hasAll(['data']) &&
             data.data is map &&
             (!('order' in data) || data.order is list);
    }

    function isValidSettings(data) {
       return data is map;
    }

    // --- 3. Resource Rules ---

    // Connection Test Path
    match /test/connection {
      allow get: if true;
    }

    // Collection: Users
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin() && userId != request.auth.uid;

      // User-specific Pricing
      match /pricing/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      // User-specific Sales
      match /sales/{saleId} {
        allow read: if isSignedIn();
        allow create: if (isEditor() || isAdmin()) && request.auth.token.email_verified == true && isValidSale(incoming());
        allow update, delete: if isEditor() || isAdmin();
      }

      // User-specific Settings
      match /settings/{settingId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // --- Legacy Top-Level Collections (Disabled) ---
    // All data is now under /users/{userId}/...
  }
}
