rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Pricing Items
    function isValidPricingItem(data) {
      return data.keys().hasAll(['itemName', 'sizes']) && 
             data.keys().size() == 2 &&
             data.itemName is string && data.itemName.size() <= 100 &&
             data.sizes is map && data.sizes.size() <= 100;
    }

    match /pricing/{itemId} {
      allow get: if isSignedIn() && isValidId(itemId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidPricingItem(incoming()) && isValidId(itemId);
      allow update: if isSignedIn() && isValidPricingItem(incoming()) && 
                     incoming().diff(existing()).affectedKeys().hasOnly(['sizes', 'itemName']);
      allow delete: if isSignedIn() && isValidId(itemId);
    }

    // Sale Records
    function isValidSaleRecord(data) {
      return data.keys().hasAll(['srNo', 'name', 'studentClass', 'items', 'totalAmount', 'date', 'timestamp', 'paymentMode']) &&
             data.srNo is number &&
             data.name is string && data.name.size() <= 200 &&
             data.studentClass is string && data.studentClass.size() <= 50 &&
             data.items is list && data.items.size() <= 50 &&
             data.totalAmount is number &&
             data.date is string && data.date.size() <= 32 &&
             data.timestamp is string && data.timestamp.size() <= 64 &&
             data.paymentMode in ['UPI', 'Cash', 'Pending'] &&
             (!('notes' in data) || (data.notes is string && data.notes.size() <= 2000)) &&
             (!('paidAmount' in data) || data.paidAmount is number) &&
             (!('paymentDate' in data) || data.paymentDate is string) &&
             (!('customData' in data) || data.customData is map);
    }

    match /sales/{saleId} {
      allow get: if isSignedIn() && isValidId(saleId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidSaleRecord(incoming()) && isValidId(saleId);
      allow update: if isSignedIn() && isValidSaleRecord(incoming()) && 
                     incoming().diff(existing()).affectedKeys().hasOnly(['paymentMode', 'paidAmount', 'paymentDate', 'notes', 'customData']);
      allow delete: if isSignedIn() && isValidId(saleId);
    }

    // Custom Fields
    function isValidCustomField(data) {
      return data.keys().hasAll(['label', 'type', 'required']) &&
             data.keys().size() == 3 &&
             data.label is string && data.label.size() <= 100 &&
             data.type in ['text', 'number', 'date'] &&
             data.required is bool;
    }

    match /customFields/{fieldId} {
      allow get: if isSignedIn() && isValidId(fieldId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidCustomField(incoming()) && isValidId(fieldId);
      allow update: if isSignedIn() && isValidCustomField(incoming()) && 
                     incoming().diff(existing()).affectedKeys().hasOnly(['label', 'type', 'required']);
      allow delete: if isSignedIn() && isValidId(fieldId);
    }
  }
}
