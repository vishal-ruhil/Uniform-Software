{
  "entities": {
    "PricingItem": {
      "title": "Pricing Item",
      "description": "Configuration for an item's prices across different sizes",
      "type": "object",
      "properties": {
        "itemName": { "type": "string" },
        "sizes": { "type": "object" }
      },
      "required": ["itemName", "sizes"]
    },
    "SaleRecord": {
      "title": "Sale Record",
      "description": "A completed transaction for a student",
      "type": "object",
      "properties": {
        "srNo": { "type": "number" },
        "name": { "type": "string" },
        "studentClass": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "date": { "type": "string" },
        "timestamp": { "type": "string" },
        "paymentMode": { "type": "string" },
        "paidAmount": { "type": "number" },
        "paymentDate": { "type": "string" },
        "notes": { "type": "string" },
        "customData": { "type": "object" }
      },
      "required": ["srNo", "name", "studentClass", "items", "totalAmount", "date", "timestamp", "paymentMode"]
    },
    "CustomField": {
      "title": "Custom Field",
      "description": "Dynamic field definition for the sales form",
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "number", "date"] },
        "required": { "type": "boolean" }
      },
      "required": ["label", "type", "required"]
    }
  },
  "firestore": {
    "pricing": {
      "schema": "PricingItem",
      "description": "Global items and their size-based pricing"
    },
    "sales": {
      "schema": "SaleRecord",
      "description": "All completed sales transactions"
    },
    "customFields": {
      "schema": "CustomField",
      "description": "Definitions for extra fields in the sales form"
    }
  }
}
